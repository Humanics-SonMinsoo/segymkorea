# 어드민 로그인 (/admin/login)
# 코드에 기본값 없음. 모두 비우면 로그인 불가. 운영(Vercel)에서 반드시 설정.
# ID 8자 이상, 비밀번호 16자 이상, 시크릿 32자 이상.
LEADS_ADMIN_ID=
LEADS_ADMIN_PASSWORD=

# 세션 쿠키 HMAC용 (운영에서는 긴 임의 문자열 필수)
ADMIN_SESSION_SECRET=

# 공개 사이트 URL (OG 등 메타데이터용). 끝 슬래시 없이.
# 카카오 미리보기(og:image)는 이 주소 + /images/segym_new.png 로 열려야 합니다.
# segymkorea.com DNS가 아직이면 비우기(빌드 시 vercel.app 사용) 또는 https://프로젝트.vercel.app 로 두세요.
NEXT_PUBLIC_SITE_URL=

# 카카오 비즈니스 채널(채팅) URL — 비워 두면 플로팅 위젯에는 도입 문의만 노출됩니다.
# 예: https://pf.kakao.com/_xxxxx/chat
NEXT_PUBLIC_KAKAO_CHANNEL_URL=
